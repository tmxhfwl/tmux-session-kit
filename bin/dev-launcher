#!/usr/bin/env bash
# dev-launcher — dev tool launcher for a tmux popup (bound to M-q in tmux.conf)
set -uo pipefail

# tmux popups may not inherit the login shell PATH; supplement it explicitly
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$HOME/go/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# ── i18n ────────────────────────────────────────────────────
CONFIG_DIR="$HOME/.config/fleetmux"
TSK_CONFIG="$CONFIG_DIR/config"
LAUNCHER_CONF="$CONFIG_DIR/launcher.conf"
TSK_LANG="en"
# shellcheck source=/dev/null
[[ -f "$TSK_CONFIG" ]] && source "$TSK_CONFIG"

if [[ "$TSK_LANG" == "ko" ]]; then
  MSG_ERROR_PREFIX="오류"
  MSG_NOT_FOUND_FMT="'%s' 프로그램이 설치되어 있지 않거나 PATH에서 찾을 수 없습니다."
  MSG_PRESS_ENTER="Enter를 누르면 메뉴로 돌아갑니다..."
else
  MSG_ERROR_PREFIX="Error"
  MSG_NOT_FOUND_FMT="'%s' is not installed or not found in PATH."
  MSG_PRESS_ENTER="Press Enter to return to the menu..."
fi

pause_with_error() {
  printf '\n%s: %s\n\n' "$MSG_ERROR_PREFIX" "$1"
  read -r -p "$MSG_PRESS_ENTER"
}

run_command() {
  local command_name="$1"
  shift
  if command -v "$command_name" >/dev/null 2>&1; then
    "$command_name" "$@"
  else
    pause_with_error "$(printf "$MSG_NOT_FOUND_FMT" "$command_name")"
  fi
}

# Custom menu entries: ~/.config/fleetmux/launcher.conf, one per line:
#   icon|label|command
# e.g.  |htop|htop
build_menu() {
  printf '%s\n' \
    "󰆍  Sessions" \
    "󰕰  Tree" \
    "󰊢  Git" \
    "󰡨  Docker" \
    "󰉋  Files" \
    "󰚩  Claude"
  if [[ -f "$LAUNCHER_CONF" ]]; then
    local icon label cmd
    while IFS='|' read -r icon label cmd; do
      [[ -z "$label" || "$icon" == \#* ]] && continue
      printf '%s  %s\n' "${icon:- }" "$label"
    done <"$LAUNCHER_CONF"
  fi
  printf '%s\n' "󰩈  Exit"
}

custom_command_for() {
  # custom_command_for <label> — look up the command for a custom menu label
  local wanted="$1" icon label cmd
  [[ -f "$LAUNCHER_CONF" ]] || return 1
  while IFS='|' read -r icon label cmd; do
    [[ -z "$label" || "$icon" == \#* ]] && continue
    if [[ "$label" == "$wanted" ]]; then
      printf '%s' "$cmd"
      return 0
    fi
  done <"$LAUNCHER_CONF"
  return 1
}

while true; do
  choice=$(
    build_menu |
      fzf \
        --height=100% \
        --layout=reverse \
        --border=rounded \
        --prompt="Open > " \
        --pointer="▶" \
        --marker="✓" \
        --info=inline \
        --no-scrollbar
  )

  case "$choice" in
    *"Sessions")
      # tmux-sessions uses switch-client inside tmux, so it is safe
      # to run it directly inside this popup (no nesting issues).
      "$HOME/.local/bin/tmux-sessions"
      exit 0
      ;;
    *"Tree")
      # Full session > window > pane tree. +/- to expand/collapse, Enter to jump.
      tmux choose-tree -Z
      exit 0
      ;;
    *"Git")
      run_command lazygit
      ;;
    *"Docker")
      run_command lazydocker
      ;;
    *"Files")
      # Running yazi directly inside a popup can kill the tmux server due to a
      # known terminal-query bug (yazi#2308), so open it in a new window instead.
      # The popup starts in pane_current_path, so $PWD is the current pane's path.
      if command -v yazi >/dev/null 2>&1; then
        tmux new-window -c "$PWD" -n yazi "yazi"
        exit 0
      else
        pause_with_error "$(printf "$MSG_NOT_FOUND_FMT" "yazi")"
      fi
      ;;
    *"Claude")
      run_command claude
      ;;
    *"Exit"|"")
      exit 0
      ;;
    *)
      # Custom entry from launcher.conf — strip the "icon  " prefix
      label="${choice#*  }"
      if cmd=$(custom_command_for "$label"); then
        bash -c "$cmd" || pause_with_error "$(printf "$MSG_NOT_FOUND_FMT" "$label")"
      fi
      ;;
  esac
done
